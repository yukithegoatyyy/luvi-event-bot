# Copy this file to `.env` with `npm run setup`, then replace the placeholder values.
# `.env` is intentionally ignored by git so your Discord token stays secret.

# Required: Discord bot token from the Discord Developer Portal.
# The bot accepts either DISCORD_TOKEN or APIKEY. Use APIKEY if that is the
# secret name your host/repo already provides.
# Never paste a real token into .env.example, README.md, GitHub issues, or commits.
DISCORD_TOKEN=your_discord_bot_token_here
# APIKEY=your_discord_bot_token_here

# Required: Channel where Luvi reward messages are posted.
CHANNEL_ID=your_reward_channel_id_here

# Required: User ID of the Luvi bot whose messages should be processed.
LUVI_BOT_ID=luvi_bot_user_id_here

# Optional: Guild ID for faster slash-command registration during development.
# If omitted, commands are registered globally and can take longer to appear.
GUILD_ID=your_test_server_id_here

# Optional: custom path for persistent point storage.
DATA_FILE=./data/points.json

# Optional: set by many hosts automatically. When present, the bot starts a
# tiny HTTP health server at /health so web-service hosts can keep it live.
# PORT=3000
