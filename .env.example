# Required: Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=your_discord_bot_token_here

# Required: Channel where Luvi reward messages are posted.
CHANNEL_ID=your_reward_channel_id_here

# Required: User ID of the Luvi bot whose messages should be processed.
LUVI_BOT_ID=luvi_bot_user_id_here

# Optional: Guild ID for faster slash-command registration during development.
# If omitted, commands are registered globally and can take longer to appear.
GUILD_ID=your_test_server_id_here

# Optional: custom path for persistent point storage.
DATA_FILE=./data/points.json
